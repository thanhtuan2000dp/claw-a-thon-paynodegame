# --- GreenNode IAM (local dev only; auto-injected on AgentBase Runtime) ---
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=

# --- LLM provider (OpenAI-compatible: GreenNode MaaS) ---
# GreenNode AIP: use /agentbase-llm to get a key; base URL below.
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=

# --- Sensor Tower (formerly data.ai / App Annie) ---
# Premium connector: reviews-with-dates, downloads/revenue, rankings.
# Leave empty to run on free sources only (iTunes + Google Play).
SENSORTOWER_AUTH_TOKEN=

# --- Defaults ---
DEFAULT_STORE=ios
DEFAULT_COUNTRY=us

# --- Memory (added when Hypothesis Checker / multi-turn is built) ---
MEMORY_ID=
